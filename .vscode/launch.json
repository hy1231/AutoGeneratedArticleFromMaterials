{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run WeChat Writer",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "args": [
        "--profile",
        "chenwu",
        "--input",
        "rawdata/chenwu/xinli.md"
      ]
    }
  ]
}
